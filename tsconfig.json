{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "./src", 
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx" 
  },
  "include": ["src/**/*"]
}